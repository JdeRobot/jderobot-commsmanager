{
  "compilerOptions": {
    "outDir": "./dist/",
    "rootDir": "./src",
    "noImplicitAny": true,
    "module": "nodenext",
    "target": "es2025",
    "allowJs": true,
    "moduleResolution": "nodenext",
    "declaration": true,
    "paths": {
      "Utils": ["./src/utils"],
      "Types": ["./src/types"]
    }
  },
  "include": ["src", "svg.d.ts"]
}
